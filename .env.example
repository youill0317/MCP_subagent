# Minimal single-provider setup
# Pick exactly one DEFAULT_PROVIDER and set only its required credential.
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# For DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# For DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# For DEFAULT_PROVIDER=google
GOOGLE_API_KEY=

# For DEFAULT_PROVIDER=custom
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://api.openai.com/v1

# For DEFAULT_PROVIDER=codex
CODEX_ENABLED=false
CODEX_CLI_PATH=codex
CODEX_MODEL_DEFAULT=gpt-5-codex

# Optional provider base URLs (keep defaults unless needed)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# MCP server env (optional if STRICT_CONFIG_VALIDATION=false)
MARKDOWN_BASE_DIR=
BRAVE_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Runtime
MAX_AGENT_ITERATIONS=15
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_MS=300000
STRICT_CONFIG_VALIDATION=false
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_PER_SECOND=5
