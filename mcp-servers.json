{
  "servers": {
    "mcp_search": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "description": "Provides Exa web search and research tools"
    },
    "mcp_obsidian": {
      "command": "node",
      "args": ["../../My_mcp/dist/index.js"],
      "env": {
        "MARKDOWN_BASE_DIR": "../../Obsidian"
      },
      "description": "Provides tools to browse and read Obsidian markdown files"
    }
  }
}
