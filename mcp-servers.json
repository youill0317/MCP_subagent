{
  "servers": {
    "mcp_search": {
      "command": "node",
      "args": ["../../MCP_search/dist/index.js"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "description": "Provides web search, paper search, and news search tools"
    },
    "mcp_obsidian": {
      "command": "node",
      "args": ["../../My_mcp/dist/index.js"],
      "env": {
        "MARKDOWN_BASE_DIR": "../../Obsidian"
      },
      "description": "Provides tools to browse and read Obsidian markdown files"
    }
  }
}
